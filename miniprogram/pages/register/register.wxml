<view class="register-container">
  <view class="register-header">
    <text class="title">用户注册</text>
    <text class="subtitle">创建您的账号</text>
  </view>

  <view class="register-form">
    <view class="form-item">
      <view class="form-label">账号</view>
      <input class="form-input" placeholder="请输入账号（字母或数字）" value="{{account}}" bindinput="onAccountInput" />
    </view>

    <view class="form-item">
      <view class="form-label">手机号</view>
      <input class="form-input" type="number" placeholder="请输入手机号" value="{{phone}}" bindinput="onPhoneInput" />
    </view>

    <view class="form-item">
      <view class="form-label">姓名</view>
      <input class="form-input" placeholder="请输入真实姓名" value="{{name}}" bindinput="onNameInput" />
    </view>

    <view class="form-item">
      <view class="form-label">密码</view>
      <input class="form-input" placeholder="请输入密码（至少6位）" password value="{{password}}" bindinput="onPasswordInput" />
    </view>

    <view class="form-item">
      <view class="form-label">确认密码</view>
      <input class="form-input" placeholder="请再次输入密码" password value="{{confirmPassword}}" bindinput="onConfirmPasswordInput" />
    </view>

    <view class="form-item">
      <view class="form-label">所属部门</view>
      <picker mode="selector" range="{{departments}}" value="{{departmentIndex}}" bindchange="onDepartmentChange">
        <view class="picker-value">
          {{departments[departmentIndex] || '请选择部门'}}
          <text class="picker-arrow">></text>
        </view>
      </picker>
    </view>

    <view class="agreement">
      <checkbox checked="{{agreed}}" bindtap="toggleAgreement" color="#1890ff" />
      <text class="agreement-text">我已阅读并同意</text>
      <text class="agreement-link" bindtap="showAgreement">《用户协议》</text>
    </view>

    <button class="btn-primary register-btn" bindtap="handleRegister" loading="{{loading}}">注册</button>

    <view class="register-footer">
      <text class="link" bindtap="goToLogin">已有账号？立即登录</text>
    </view>
  </view>
</view>
