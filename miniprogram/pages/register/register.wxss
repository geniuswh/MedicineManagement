.register-container {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 60rpx 40rpx;
}

.register-header {
  text-align: center;
  margin-bottom: 50rpx;
}

.title {
  display: block;
  font-size: 44rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
}

.subtitle {
  display: block;
  font-size: 28rpx;
  color: #999;
}

.register-form {
  background: #fff;
  border-radius: 20rpx;
  padding: 40rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.form-item {
  background: #f7f8fa;
  border-radius: 12rpx;
  padding: 24rpx 30rpx;
  margin-bottom: 24rpx;
}

.form-label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 12rpx;
}

.form-input {
  font-size: 30rpx;
  color: #333;
}

.picker-value {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 30rpx;
  color: #333;
}

.picker-arrow {
  color: #ccc;
}

.agreement {
  display: flex;
  align-items: center;
  margin: 30rpx 0;
  font-size: 26rpx;
}

.agreement-text {
  margin-left: 12rpx;
  color: #666;
}

.agreement-link {
  color: #1890ff;
}

.register-btn {
  margin-top: 20rpx;
}

.register-footer {
  text-align: center;
  margin-top: 30rpx;
}

.link {
  color: #1890ff;
  font-size: 28rpx;
}
