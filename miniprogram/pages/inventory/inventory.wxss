.inventory-container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 120rpx;
}

/* 搜索栏 */
.search-bar {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: #fff;
  gap: 20rpx;
}

.search-input-wrapper {
  flex: 1;
  display: flex;
  align-items: center;
  background: #f5f5f5;
  border-radius: 30rpx;
  padding: 16rpx 24rpx;
}

.search-input-wrapper .iconfont {
  color: #999;
  margin-right: 12rpx;
  font-size: 32rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
}

.filter-btn {
  width: 64rpx;
  height: 64rpx;
  background: #1890ff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.filter-btn .iconfont {
  color: #fff;
  font-size: 32rpx;
}

/* 标签栏 */
.tab-bar {
  display: flex;
  background: #fff;
  border-bottom: 1rpx solid #f0f0f0;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: #666;
  position: relative;
}

.tab-item.active {
  color: #1890ff;
  font-weight: bold;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 4rpx;
  background: #1890ff;
  border-radius: 2rpx;
}

/* 记录列表 */
.record-list {
  padding: 20rpx;
  height: calc(100vh - 280rpx);
}

.record-item {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.record-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.inbound-icon {
  background: rgba(82, 196, 26, 0.1);
}

.inbound-icon .iconfont {
  color: #52c41a;
  font-size: 40rpx;
}

.outbound-icon {
  background: rgba(24, 144, 255, 0.1);
}

.outbound-icon .iconfont {
  color: #1890ff;
  font-size: 40rpx;
}

.record-content {
  flex: 1;
}

.record-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.record-name {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
}

.record-amount {
  font-size: 30rpx;
  font-weight: bold;
}

.text-success {
  color: #52c41a;
}

.text-danger {
  color: #ff4d4f;
}

.record-info {
  display: flex;
  justify-content: space-between;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.record-footer {
  font-size: 24rpx;
  color: #bbb;
}

.record-arrow {
  color: #ccc;
  font-size: 28rpx;
  margin-left: 12rpx;
}

/* 浮动按钮 */
.float-buttons {
  position: fixed;
  bottom: 140rpx;
  right: 30rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.float-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  color: #fff;
  flex-direction: column;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.2);
}

.float-btn .iconfont {
  font-size: 36rpx;
  margin-bottom: 4rpx;
}

.float-btn text:last-child {
  font-size: 20rpx;
}

.inbound-btn {
  background: linear-gradient(135deg, #52c41a 0%, #73d13d 100%);
}

.outbound-btn {
  background: linear-gradient(135deg, #1890ff 0%, #40a9ff 100%);
}

/* 筛选弹窗 */
.filter-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
}

.filter-content {
  width: 100%;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  padding: 30rpx;
}

.filter-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.filter-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.filter-reset {
  color: #1890ff;
  font-size: 28rpx;
}

.filter-section {
  margin-bottom: 30rpx;
}

.filter-label {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 16rpx;
}

.filter-options {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.filter-option {
  padding: 16rpx 32rpx;
  background: #f5f5f5;
  border-radius: 30rpx;
  font-size: 28rpx;
  color: #666;
}

.filter-option.active {
  background: #e6f7ff;
  color: #1890ff;
  border: 1rpx solid #1890ff;
}

.confirm-btn {
  margin-top: 20rpx;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 100rpx 0;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  color: #999;
  font-size: 28rpx;
}

.loading {
  text-align: center;
  padding: 30rpx;
  color: #999;
}

.no-more {
  text-align: center;
  padding: 30rpx;
  color: #999;
  font-size: 24rpx;
}
