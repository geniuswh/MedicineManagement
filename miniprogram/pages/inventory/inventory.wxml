<view class="inventory-container">
  <!-- 搜索栏 -->
  <view class="search-bar">
    <view class="search-input-wrapper">
      <text class="iconfont icon-search"></text>
      <input class="search-input" placeholder="搜索产品名称、批号" value="{{keyword}}" bindinput="onSearch" />
    </view>
    <view class="filter-btn" bindtap="showFilter">
      <text class="iconfont icon-filter"></text>
    </view>
  </view>

  <!-- 标签切换 -->
  <view class="tab-bar">
    <view class="tab-item {{currentTab === 'all' ? 'active' : ''}}" bindtap="switchTab" data-tab="all">全部</view>
    <view class="tab-item {{currentTab === 'inbound' ? 'active' : ''}}" bindtap="switchTab" data-tab="inbound">入库</view>
    <view class="tab-item {{currentTab === 'outbound' ? 'active' : ''}}" bindtap="switchTab" data-tab="outbound">出库</view>
  </view>

  <!-- 记录列表 -->
  <scroll-view class="record-list" scroll-y bindscrolltolower="loadMore">
    <view class="record-item" wx:for="{{records}}" wx:key="_id">
      <view class="record-icon {{item.type === 'inbound' ? 'inbound-icon' : 'outbound-icon'}}">
        <text class="iconfont {{item.type === 'inbound' ? 'icon-inbound' : 'icon-outbound'}}"></text>
      </view>
      <view class="record-content">
        <view class="record-header">
          <text class="record-name">{{item.productName}}</text>
          <text class="record-amount {{item.type === 'inbound' ? 'text-success' : 'text-danger'}}">
            {{item.type === 'inbound' ? '+' : '-'}}{{item.quantity}} {{item.unit}}
          </text>
        </view>
        <view class="record-info">
          <text>批号: {{item.batchNo}}</text>
          <text>¥{{item.totalAmount}}</text>
        </view>
        <view class="record-footer">
          <text>{{item.operatorName}} · {{item.createTimeStr}}</text>
        </view>
      </view>
      <text class="record-arrow">></text>
    </view>

    <view class="loading" wx:if="{{loading}}">
      <text>加载中...</text>
    </view>

    <view class="empty-state" wx:if="{{!loading && records.length === 0}}">
      <image class="empty-icon" src="/images/empty.png" mode="aspectFit"></image>
      <text class="empty-text">暂无记录</text>
    </view>

    <view class="no-more" wx:if="{{!loading && records.length > 0 && noMore}}">
      <text>没有更多了</text>
    </view>
  </scroll-view>

  <!-- 浮动按钮 -->
  <view class="float-buttons">
    <view class="float-btn inbound-btn" bindtap="goToInbound">
      <text class="iconfont icon-inbound"></text>
      <text>入库</text>
    </view>
    <view class="float-btn outbound-btn" bindtap="goToOutbound">
      <text class="iconfont icon-outbound"></text>
      <text>出库</text>
    </view>
  </view>
</view>

<!-- 筛选弹窗 -->
<view class="filter-modal" wx:if="{{showFilterModal}}" bindtap="closeFilter">
  <view class="filter-content" catchtap="stopPropagation">
    <view class="filter-header">
      <text class="filter-title">筛选条件</text>
      <text class="filter-reset" bindtap="resetFilter">重置</text>
    </view>
    
    <view class="filter-section">
      <text class="filter-label">时间范围</text>
      <view class="filter-options">
        <view class="filter-option {{filterDate === 'today' ? 'active' : ''}}" bindtap="selectFilterDate" data-value="today">今日</view>
        <view class="filter-option {{filterDate === 'week' ? 'active' : ''}}" bindtap="selectFilterDate" data-value="week">本周</view>
        <view class="filter-option {{filterDate === 'month' ? 'active' : ''}}" bindtap="selectFilterDate" data-value="month">本月</view>
      </view>
    </view>

    <view class="filter-section">
      <text class="filter-label">产品类型</text>
      <view class="filter-options">
        <view class="filter-option {{filterType === 'all' ? 'active' : ''}}" bindtap="selectFilterType" data-value="all">全部</view>
        <view class="filter-option {{filterType === 'medicine' ? 'active' : ''}}" bindtap="selectFilterType" data-value="medicine">药品</view>
        <view class="filter-option {{filterType === 'device' ? 'active' : ''}}" bindtap="selectFilterType" data-value="device">器械</view>
      </view>
    </view>

    <button class="btn-primary confirm-btn" bindtap="confirmFilter">确定</button>
  </view>
</view>
