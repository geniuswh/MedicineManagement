.inbound-container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 120rpx;
}

/* 扫码区域 */
.scan-section {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #52c41a 0%, #73d13d 100%);
  color: #fff;
  padding: 40rpx;
  margin: 20rpx;
  border-radius: 16rpx;
}

.scan-section .iconfont {
  font-size: 48rpx;
  margin-right: 16rpx;
}

.scan-section text:last-child {
  font-size: 32rpx;
}

/* 表单 */
.form-section {
  background: #fff;
  margin: 20rpx;
  border-radius: 16rpx;
  padding: 30rpx;
}

.form-item {
  margin-bottom: 30rpx;
}

.form-item.half {
  flex: 1;
}

.form-item.required .form-label::before {
  content: '*';
  color: #ff4d4f;
  margin-right: 4rpx;
}

.form-row {
  display: flex;
  gap: 20rpx;
}

.form-label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.form-input {
  width: 100%;
  background: #f7f8fa;
  border-radius: 12rpx;
  padding: 24rpx 30rpx;
  font-size: 30rpx;
  color: #333;
}

.form-value {
  background: #f7f8fa;
  border-radius: 12rpx;
  padding: 24rpx 30rpx;
  font-size: 32rpx;
  font-weight: bold;
  color: #1890ff;
}

.form-textarea {
  width: 100%;
  min-height: 160rpx;
  background: #f7f8fa;
  border-radius: 12rpx;
  padding: 24rpx 30rpx;
  font-size: 30rpx;
  color: #333;
}

.picker-value {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #f7f8fa;
  border-radius: 12rpx;
  padding: 24rpx 30rpx;
  font-size: 30rpx;
  color: #333;
}

.picker-arrow {
  color: #ccc;
}

/* 提交按钮 */
.submit-section {
  padding: 20rpx;
}

.submit-btn {
  margin-top: 20rpx;
}

/* 产品选择弹窗 */
.product-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
}

.modal-content {
  width: 100%;
  max-height: 80vh;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.modal-close {
  font-size: 48rpx;
  color: #999;
}

.modal-search {
  padding: 20rpx 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.search-input {
  background: #f7f8fa;
  border-radius: 30rpx;
  padding: 20rpx 30rpx;
  font-size: 28rpx;
}

.modal-list {
  max-height: 60vh;
  padding: 0 30rpx;
}

.product-item {
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.product-name {
  display: block;
  font-size: 30rpx;
  color: #333;
  margin-bottom: 8rpx;
}

.product-spec {
  font-size: 24rpx;
  color: #999;
}
