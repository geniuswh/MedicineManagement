.device-list {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 20rpx;
}

.device-card {
  display: flex;
  justify-content: space-between;
  background: #fff;
  padding: 30rpx;
  margin-bottom: 20rpx;
  border-radius: 12rpx;
}

.device-name {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 10rpx;
}

.device-spec {
  font-size: 26rpx;
  color: #999;
}

.device-manufacturer {
  font-size: 24rpx;
  color: #ccc;
  margin-top: 6rpx;
}

.device-price {
  font-size: 32rpx;
  color: #ff4d4f;
  font-weight: 500;
}

.device-stock {
  font-size: 24rpx;
  color: #52c41a;
  margin-top: 10rpx;
}
