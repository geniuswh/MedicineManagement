<view class="device-list">
  <view wx:if="{{ loading }}" class="loading-wrap">
    <text>加载中...</text>
  </view>
  
  <view class="list-container" wx:if="{{ !loading }}">
    <view class="device-card" wx:for="{{ devices }}" wx:key="id" bindtap="goToDetail" data-id="{{ item.id }}">
      <view class="device-info">
        <view class="device-name">{{ item.name }}</view>
        <view class="device-spec">{{ item.spec }}</view>
        <view class="device-manufacturer">{{ item.manufacturer }}</view>
      </view>
      <view class="device-meta">
        <view class="device-price">¥{{ item.price }}</view>
        <view class="device-stock">库存: {{ item.stock }} {{ item.unit }}</view>
      </view>
    </view>
  </view>
</view>
