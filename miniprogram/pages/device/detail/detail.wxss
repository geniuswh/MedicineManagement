.detail-page { min-height: 100vh; background: #f5f5f5; padding: 20rpx; }
.info-card { background: #fff; border-radius: 12rpx; padding: 30rpx; margin-bottom: 20rpx; }
.info-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20rpx; padding-bottom: 20rpx; border-bottom: 1rpx solid #eee; }
.info-title { font-size: 36rpx; font-weight: 600; color: #333; }
.info-row { display: flex; justify-content: space-between; padding: 16rpx 0; border-bottom: 1rpx solid #f5f5f5; }
.info-label { color: #999; font-size: 28rpx; }
.info-value { color: #333; font-size: 28rpx; }
.info-value.price { color: #ff4d4f; font-weight: 500; }
.action-buttons { display: flex; gap: 20rpx; margin-top: 30rpx; }
