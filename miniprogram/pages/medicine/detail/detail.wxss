.detail-page {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 20rpx;
}

.loading-wrap {
  text-align: center;
  padding: 100rpx;
  color: #999;
}

.info-card {
  background: #fff;
  border-radius: 12rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.info-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #eee;
}

.info-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
}

.category-tag {
  background: #1890ff;
  color: #fff;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 20rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  color: #999;
  font-size: 28rpx;
}

.info-value {
  color: #333;
  font-size: 28rpx;
}

.info-value.price {
  color: #ff4d4f;
  font-weight: 500;
}

.info-value.warning {
  color: #ff4d4f;
}

.action-buttons {
  display: flex;
  gap: 20rpx;
  margin-top: 30rpx;
}

.btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 12rpx;
  font-size: 32rpx;
  border: none;
}

.btn-primary {
  background: #1890ff;
  color: #fff;
}

.btn-info {
  background: #52c41a;
  color: #fff;
}
