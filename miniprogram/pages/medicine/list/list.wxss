.medicine-list {
  min-height: 100vh;
  background: #f5f5f5;
}

.search-bar {
  background: #fff;
  padding: 10rpx 0;
}

.category-scroll {
  white-space: nowrap;
  padding: 20rpx;
  background: #fff;
  border-bottom: 1rpx solid #eee;
}

.category-item {
  display: inline-block;
  padding: 10rpx 30rpx;
  margin-right: 20rpx;
  font-size: 28rpx;
  color: #666;
  background: #f5f5f5;
  border-radius: 30rpx;
}

.category-item.active {
  color: #fff;
  background: #1890ff;
}

.list-container {
  padding: 20rpx;
}

.medicine-card {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #fff;
  padding: 30rpx;
  margin-bottom: 20rpx;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.medicine-info {
  flex: 1;
}

.medicine-name {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 10rpx;
}

.medicine-spec {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 6rpx;
}

.medicine-manufacturer {
  font-size: 24rpx;
  color: #ccc;
}

.medicine-meta {
  text-align: right;
}

.medicine-price {
  font-size: 32rpx;
  color: #ff4d4f;
  font-weight: 500;
  margin-bottom: 10rpx;
}

.medicine-stock {
  font-size: 24rpx;
  color: #52c41a;
}

.medicine-stock.warning {
  color: #ff4d4f;
}
