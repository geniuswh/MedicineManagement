.index-container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 120rpx;
}

/* 欢迎卡片 */
.welcome-card {
  background: linear-gradient(135deg, #1890ff 0%, #36cfc9 100%);
  margin: 20rpx;
  border-radius: 20rpx;
  padding: 40rpx 30rpx;
  color: #fff;
}

.welcome-info {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.5);
  margin-right: 24rpx;
}

.user-info {
  flex: 1;
}

.user-name {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.user-role {
  display: inline-block;
  background: rgba(255, 255, 255, 0.2);
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
}

.welcome-stats {
  display: flex;
  align-items: center;
  justify-content: space-around;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 16rpx;
  padding: 30rpx 0;
}

.stat-item {
  text-align: center;
  flex: 1;
}

.stat-value {
  display: block;
  font-size: 44rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  opacity: 0.9;
}

.stat-divider {
  width: 1rpx;
  height: 60rpx;
  background: rgba(255, 255, 255, 0.3);
}

/* 快捷功能 */
.quick-actions {
  margin: 20rpx;
}

.section-title {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.warning-count {
  background: #ff4d4f;
  color: #fff;
  font-size: 24rpx;
  padding: 2rpx 12rpx;
  border-radius: 20rpx;
  margin-left: 12rpx;
}

.more-link {
  font-size: 26rpx;
  font-weight: normal;
  color: #1890ff;
}

.action-grid {
  display: flex;
  flex-wrap: wrap;
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx 10rpx;
}

.action-item {
  width: 33.33%;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 30rpx;
}

.action-icon {
  width: 100rpx;
  height: 100rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}

.action-icon .iconfont {
  font-size: 48rpx;
  color: #fff;
}

.inbound-bg {
  background: linear-gradient(135deg, #52c41a 0%, #73d13d 100%);
}

.outbound-bg {
  background: linear-gradient(135deg, #1890ff 0%, #40a9ff 100%);
}

.medicine-bg {
  background: linear-gradient(135deg, #722ed1 0%, #9254de 100%);
}

.device-bg {
  background: linear-gradient(135deg, #fa8c16 0%, #ffa940 100%);
}

.stats-bg {
  background: linear-gradient(135deg, #eb2f96 0%, #f759ab 100%);
}

.scan-bg {
  background: linear-gradient(135deg, #13c2c2 0%, #36cfc9 100%);
}

.action-name {
  font-size: 26rpx;
  color: #666;
}

/* 库存预警 */
.warning-section {
  margin: 20rpx;
}

.warning-list {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}

.warning-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.warning-item:last-child {
  border-bottom: none;
}

.warning-info {
  flex: 1;
}

.warning-name {
  display: block;
  font-size: 30rpx;
  color: #333;
  margin-bottom: 8rpx;
}

.warning-spec {
  font-size: 24rpx;
  color: #999;
}

/* 最近记录 */
.recent-section {
  margin: 20rpx;
}

.record-list {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}

.record-item {
  display: flex;
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.record-item:last-child {
  border-bottom: none;
}

.record-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.record-icon .iconfont {
  font-size: 40rpx;
  color: #fff;
}

.record-info {
  flex: 1;
}

.record-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.record-name {
  font-size: 30rpx;
  color: #333;
}

.record-amount {
  font-size: 30rpx;
  font-weight: bold;
}

.text-success {
  color: #52c41a;
}

.text-danger {
  color: #ff4d4f;
}

.record-detail {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.record-time {
  font-size: 24rpx;
  color: #bbb;
}

/* 标签 */
.tag {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
}

.tag-danger {
  background: #fff2f0;
  color: #ff4d4f;
  border: 1rpx solid #ffccc7;
}

.tag-warning {
  background: #fffbe6;
  color: #faad14;
  border: 1rpx solid #ffe58f;
}
